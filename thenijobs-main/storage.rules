rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ===== HELPER FUNCTIONS =====
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated()
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin'];
    }

    function currentUserData() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }

    function isMobileVerified() {
      return isAuthenticated()
        && (
          isAdmin()
          || currentUserData().mobileVerified == true
          || currentUserData().phoneVerified == true
        );
    }

    // Max file sizes
    function isUnder5MB() {
      return request.resource.size < 5 * 1024 * 1024;
    }

    function isUnder10MB() {
      return request.resource.size < 10 * 1024 * 1024;
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isPDF() {
      return request.resource.contentType == 'application/pdf';
    }

    function isWordDocument() {
      return request.resource.contentType == 'application/msword'
        || request.resource.contentType == 'application/vnd.openxmlformats-officedocument.wordprocessingml.document';
    }

    function isResumeFile() {
      return isPDF() || isWordDocument();
    }

    // ===== USER PROFILE PHOTOS =====
    match /users/{userId}/profile/{fileName} {
      allow read: if true;
      allow create, update: if isOwner(userId) && isMobileVerified() && isImage() && isUnder5MB();
      allow delete: if (isOwner(userId) && isMobileVerified()) || isAdmin();
    }

    match /seekers/{userId}/{fileName} {
      allow read: if true;
      allow create, update: if isOwner(userId) && isMobileVerified() && isImage() && isUnder5MB();
      allow delete: if (isOwner(userId) && isMobileVerified()) || isAdmin();
    }

    // ===== COMPANY LOGOS & COVERS =====
    match /companies/{ownerId}/logo/{fileName} {
      allow read: if true;
      allow create, update: if ((isOwner(ownerId) && isMobileVerified()) || isAdmin()) && isImage() && isUnder5MB();
      allow delete: if (isOwner(ownerId) && isMobileVerified()) || isAdmin();
    }

    match /companies/{ownerId}/cover/{fileName} {
      allow read: if true;
      allow create, update: if ((isOwner(ownerId) && isMobileVerified()) || isAdmin()) && isImage() && isUnder10MB();
      allow delete: if (isOwner(ownerId) && isMobileVerified()) || isAdmin();
    }

    // ===== COMPANY GALLERY =====
    match /companies/{ownerId}/gallery/{fileName} {
      allow read: if true;
      allow create, update: if ((isOwner(ownerId) && isMobileVerified()) || isAdmin()) && (isImage() || request.resource.contentType.matches('video/.*')) && isUnder10MB();
      allow delete: if (isOwner(ownerId) && isMobileVerified()) || isAdmin();
    }

    match /companies/{ownerId}/{fileName} {
      allow read: if true;
      allow create, update: if ((isOwner(ownerId) && isMobileVerified()) || isAdmin()) && isImage() && isUnder10MB();
      allow delete: if (isOwner(ownerId) && isMobileVerified()) || isAdmin();
    }

    // ===== RESUMES =====
    match /resumes/{userId}/{fileName} {
      // Resume URLs are stored on application/profile documents; direct object reads stay owner/admin scoped.
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) && isMobileVerified() && isResumeFile() && isUnder5MB();
      allow delete: if (isOwner(userId) && isMobileVerified()) || isAdmin();
    }

    // ===== GST / VERIFICATION DOCUMENTS =====
    match /verification/{ownerId}/{fileName} {
      allow read: if isOwner(ownerId) || isAdmin();
      allow create, update: if ((isOwner(ownerId) && isMobileVerified()) || isAdmin()) && (isImage() || isPDF()) && isUnder5MB();
      allow delete: if (isOwner(ownerId) && isMobileVerified()) || isAdmin();
    }

    // ===== CATCH-ALL: Deny everything else =====
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
