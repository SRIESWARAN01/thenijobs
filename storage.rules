rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ===== HELPER FUNCTIONS =====
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Max file sizes
    function isUnder5MB() {
      return request.resource.size < 5 * 1024 * 1024;
    }

    function isUnder10MB() {
      return request.resource.size < 10 * 1024 * 1024;
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isPDF() {
      return request.resource.contentType == 'application/pdf';
    }

    // ===== USER PROFILE PHOTOS =====
    match /users/{userId}/profile/{fileName} {
      allow read: if true;
      allow write: if isOwner(userId) && isImage() && isUnder5MB();
    }

    // ===== COMPANY LOGOS & COVERS =====
    match /companies/{companyId}/logo/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated() && isImage() && isUnder5MB();
    }

    match /companies/{companyId}/cover/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated() && isImage() && isUnder10MB();
    }

    // ===== COMPANY GALLERY =====
    match /companies/{companyId}/gallery/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated() && (isImage() || request.resource.contentType.matches('video/.*')) && isUnder10MB();
    }

    // ===== RESUMES =====
    match /resumes/{userId}/{fileName} {
      // Only the owner can read/write their resume
      allow read: if isOwner(userId) || isAuthenticated();
      allow write: if isOwner(userId) && isPDF() && isUnder5MB();
    }

    // ===== GST / VERIFICATION DOCUMENTS =====
    match /verification/{companyId}/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isImage() || isPDF()) && isUnder5MB();
    }

    // ===== CATCH-ALL: Deny everything else =====
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
