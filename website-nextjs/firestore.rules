rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== HELPERS =====
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasAdminClaim() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    function hasStoredAdminRole() {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin'
      );
    }

    function isAdmin() {
      return hasAdminClaim() || hasStoredAdminRole();
    }

    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.super_admin == true ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin'
        )
      );
    }

    function isCompanyOwner(companyId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/companies/$(companyId)) &&
        get(/databases/$(database)/documents/companies/$(companyId)).data.ownerId == request.auth.uid;
    }

    function optionalFalse(field) {
      return !request.resource.data.keys().hasAny([field]) || request.resource.data[field] == false;
    }

    function optionalFalseOrUnchanged(field) {
      return !request.resource.data.keys().hasAny([field]) ||
        request.resource.data[field] == false ||
        request.resource.data[field] == resource.data[field];
    }

    function unchanged(field) {
      return request.resource.data[field] == resource.data[field];
    }

    function isEndUserRole(role) {
      return role in ['job_seeker', 'employer', 'business_owner', 'supplier', 'service_provider', 'entrepreneur'];
    }

    function hasEmployerRole() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['employer', 'business_owner', 'supplier', 'service_provider', 'entrepreneur'];
    }

    function isApprovedCompanyForCurrentUser(companyId) {
      return exists(/databases/$(database)/documents/companies/$(companyId))
        && get(/databases/$(database)/documents/companies/$(companyId)).data.ownerId == request.auth.uid
        && get(/databases/$(database)/documents/companies/$(companyId)).data.isActive != false
        && (
          get(/databases/$(database)/documents/companies/$(companyId)).data.verificationStatus == 'verified' ||
          get(/databases/$(database)/documents/companies/$(companyId)).data.status == 'approved' ||
          get(/databases/$(database)/documents/companies/$(companyId)).data.isVerified == true
        );
    }

    function hasVerifiedEmployerAccess() {
      return hasEmployerRole()
        && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.employerVerified == true ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyVerified == true ||
          (
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId != null &&
            isApprovedCompanyForCurrentUser(get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId)
          )
        );
    }

    function listHas(data, field, value) {
      return data.keys().hasAny([field]) && value in data[field];
    }

    function ownerCanChangeJobVisibility() {
      return request.resource.data.isActive == resource.data.isActive
        || request.resource.data.isActive == false
        || (
          resource.data.status in ['active', 'paused']
          && request.resource.data.status in ['active', 'paused']
          && request.resource.data.isActive == true
        );
    }

    // ===== USERS =====
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId)
        && isEndUserRole(request.resource.data.role)
        && optionalFalse('employerVerified')
        && optionalFalse('companyVerified')
        && (
          request.resource.data.isVerified == false ||
          (
            request.resource.data.isVerified == true &&
            request.auth.token.email_verified == true
          )
        );
      allow update: if isAdmin()
        || (
          isOwner(userId)
          && unchanged('role')
          && (
            unchanged('isVerified') ||
            (
              resource.data.isVerified == false &&
              request.resource.data.isVerified == true &&
              request.auth.token.email_verified == true
            )
          )
          && unchanged('adminRole')
          && unchanged('employerRole')
          && unchanged('employerVerified')
          && unchanged('companyVerified')
          && unchanged('companyId')
        );
      allow delete: if isAdmin();
    }

    // ===== COMPANIES =====
    match /companies/{companyId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.resource.data.ownerId == request.auth.uid
        && (
          request.resource.data.verificationStatus == 'pending' ||
          request.resource.data.status == 'pending'
        )
        && optionalFalse('isActive')
        && optionalFalse('isFeatured')
        && optionalFalse('isPremium');
      allow update: if isAdmin()
        || (
          resource.data.ownerId == request.auth.uid
          && request.resource.data.ownerId == resource.data.ownerId
          && request.resource.data.verificationStatus == resource.data.verificationStatus
          && optionalFalseOrUnchanged('isFeatured')
        );
      allow delete: if isAdmin();
    }

    // ===== JOBS =====
    match /jobs/{jobId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin()
        || (
          resource.data.postedBy == request.auth.uid
          && request.resource.data.postedBy == resource.data.postedBy
          && ownerCanChangeJobVisibility()
          && optionalFalseOrUnchanged('isFeatured')
          && optionalFalseOrUnchanged('isUrgent')
          && optionalFalseOrUnchanged('isPremium')
        );
      allow delete: if isAdmin()
        || (isAuthenticated() && resource.data.postedBy == request.auth.uid);
    }

    // ===== JOB APPLICATIONS =====
    match /applications/{applicationId} {
      allow read: if isAuthenticated() && (
        resource.data.seekerId == request.auth.uid ||
        isCompanyOwner(resource.data.companyId) ||
        isAdmin()
      );
      allow create: if isAuthenticated()
        && applicationId == request.auth.uid + '_' + request.resource.data.jobId
        && request.resource.data.seekerId == request.auth.uid
        && request.resource.data.status in ['applied', 'pending_review']
        && (
          !request.resource.data.keys().hasAny(['applicationType']) ||
          request.resource.data.applicationType in ['job', 'walk_in']
        )
        && exists(/databases/$(database)/documents/jobs/$(request.resource.data.jobId))
        && get(/databases/$(database)/documents/jobs/$(request.resource.data.jobId)).data.companyId == request.resource.data.companyId
        && get(/databases/$(database)/documents/jobs/$(request.resource.data.jobId)).data.isActive == true
        && get(/databases/$(database)/documents/jobs/$(request.resource.data.jobId)).data.status == 'active'
        && (
          !get(/databases/$(database)/documents/jobs/$(request.resource.data.jobId)).data.keys().hasAny(['expiresAt']) ||
          get(/databases/$(database)/documents/jobs/$(request.resource.data.jobId)).data.expiresAt > request.time
        );
      allow update: if isAdmin() || isCompanyOwner(resource.data.companyId);
      allow delete: if isAdmin();
    }

    // ===== REVIEWS =====
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.resource.data.reviewerId == request.auth.uid
        && optionalFalse('isVerified');
      allow update: if isAdmin()
        || (
          resource.data.reviewerId == request.auth.uid
          && request.resource.data.reviewerId == resource.data.reviewerId
          && request.resource.data.isVerified == resource.data.isVerified
        );
      allow delete: if isAdmin()
        || (isAuthenticated() && resource.data.reviewerId == request.auth.uid);
    }

    // ===== SEEKER PROFILES =====
    match /seekerProfiles/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ===== SAVED JOBS =====
    match /savedJobs/{savedJobId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && savedJobId == request.auth.uid + '_' + request.resource.data.jobId
        && exists(/databases/$(database)/documents/jobs/$(request.resource.data.jobId));
      allow update: if false;
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ===== LEADS =====
    match /leads/{leadId} {
      allow read: if isAdmin()
        || (isAuthenticated() && resource.data.userId == request.auth.uid)
        || (resource.data.companyId != null && isCompanyOwner(resource.data.companyId));
      allow create: if isAuthenticated();
      allow update: if isAdmin()
        || (resource.data.companyId != null && isCompanyOwner(resource.data.companyId));
      allow delete: if isAdmin();
    }

    // ===== INTERVIEWS =====
    match /interviews/{interviewId} {
      allow read: if isAdmin()
        || (isAuthenticated() && resource.data.seekerId == request.auth.uid)
        || (isAuthenticated() && resource.data.employerId == request.auth.uid)
        || (resource.data.companyId != null && isCompanyOwner(resource.data.companyId));
      allow create: if isAdmin()
        || (isAuthenticated() && request.resource.data.employerId == request.auth.uid)
        || (
          request.resource.data.companyId != null &&
          isCompanyOwner(request.resource.data.companyId)
        );
      allow update: if isAdmin()
        || (isAuthenticated() && resource.data.employerId == request.auth.uid)
        || (resource.data.companyId != null && isCompanyOwner(resource.data.companyId));
      allow delete: if isAdmin();
    }

    // ===== NOTIFICATIONS =====
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated()
        && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin()
        || (
          resource.data.userId == request.auth.uid
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'isRead'])
        );
      allow delete: if isAdmin();
    }

    // ===== JOB ALERTS =====
    match /jobAlerts/{alertId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ===== SUBSCRIPTIONS / PAYMENTS =====
    match /subscriptions/{subscriptionId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        (resource.data.companyId != null && isCompanyOwner(resource.data.companyId)) ||
        isAdmin()
      );
      allow create: if isAdmin()
        || (
          isAuthenticated()
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.plan == 'free'
          && request.resource.data.planName == 'Free Plan'
          && request.resource.data.amount == 0
          && request.resource.data.period == 'year'
          && request.resource.data.status == 'active'
        );
      allow update, delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        (resource.data.companyId != null && isCompanyOwner(resource.data.companyId)) ||
        isAdmin()
      );
      allow create, update, delete: if isAdmin();
    }

    match /paymentRequests/{requestId} {
      allow read: if isAdmin()
        || (isAuthenticated() && resource.data.userId == request.auth.uid)
        || (resource.data.companyId != null && isCompanyOwner(resource.data.companyId));
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update, delete: if isAdmin();
    }

    // ===== SETTINGS =====
    match /platformSettings/{settingsId} {
      allow read: if isAdmin();
      allow create, update, delete: if isSuperAdmin();
    }

    match /employerSettings/{companyId} {
      allow read: if isAdmin() || isCompanyOwner(companyId);
      allow create, update: if isCompanyOwner(companyId)
        && request.resource.data.companyId == companyId
        && request.resource.data.ownerId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ===== SERVICES / ADVERTISEMENTS =====
    match /services/{serviceId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.resource.data.providerId == request.auth.uid
        && request.resource.data.status == 'pending'
        && optionalFalse('isFeatured');
      allow update: if isAdmin()
        || (
          resource.data.providerId == request.auth.uid
          && request.resource.data.providerId == resource.data.providerId
          && request.resource.data.status == resource.data.status
          && optionalFalseOrUnchanged('isFeatured')
        );
      allow delete: if isAdmin();
    }

    match /advertisements/{advertisementId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ===== PUBLIC PROFILE INDEX =====
    match /publicProfiles/{profileId} {
      allow read: if isAdmin()
        || (isAuthenticated() && resource.data.ownerId == request.auth.uid)
        || (resource.data.type == 'job_seeker' && hasVerifiedEmployerAccess())
        || resource.data.type in ['employer', 'business_owner'];
      allow create: if isAuthenticated()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.type in ['job_seeker', 'employer', 'business_owner'];
      allow update: if isAdmin()
        || (
          isAuthenticated()
          && resource.data.ownerId == request.auth.uid
          && request.resource.data.ownerId == resource.data.ownerId
          && request.resource.data.type == resource.data.type
        );
      allow delete: if isAdmin()
        || (isAuthenticated() && resource.data.ownerId == request.auth.uid);
    }

    // ===== BROADCASTS / ACTIVITY LOGS =====
    match /broadcasts/{broadcastId} {
      allow read, write: if isAdmin();
    }

    match /activityLogs/{activityLogId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'userId',
          'userName',
          'action',
          'target',
          'targetId',
          'details',
          'timestamp',
          'createdAt'
        ]);
      allow update, delete: if false;
    }

    // ===== ROADMAP / SUPPORT REQUESTS =====
    match /aiCoachWaitlist/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId);
      allow delete: if isAdmin();
    }

    match /supportTickets/{ticketId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /serviceRequests/{requestId} {
      allow read: if isAdmin()
        || (isAuthenticated() && resource.data.requesterId == request.auth.uid)
        || (resource.data.providerId != null && resource.data.providerId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.requesterId == request.auth.uid;
      allow update: if isAdmin()
        || (resource.data.providerId != null && resource.data.providerId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /franchises/{franchiseId} {
      allow read: if isAdmin();
      allow create, update, delete: if isSuperAdmin();
    }

    // ===== CONVERSATIONS =====
    match /conversations/{conversationId} {
      allow read: if isAdmin()
        || (isAuthenticated() && listHas(resource.data, 'participantIds', request.auth.uid))
        || (isAuthenticated() && listHas(resource.data, 'participants', request.auth.uid));
      allow create: if isAuthenticated()
        && (
          listHas(request.resource.data, 'participantIds', request.auth.uid) ||
          listHas(request.resource.data, 'participants', request.auth.uid)
        );
      allow update: if isAdmin()
        || (isAuthenticated() && listHas(resource.data, 'participantIds', request.auth.uid))
        || (isAuthenticated() && listHas(resource.data, 'participants', request.auth.uid));
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isAdmin()
          || (isAuthenticated() && listHas(get(/databases/$(database)/documents/conversations/$(conversationId)).data, 'participantIds', request.auth.uid))
          || (isAuthenticated() && listHas(get(/databases/$(database)/documents/conversations/$(conversationId)).data, 'participants', request.auth.uid));
        allow create: if isAuthenticated()
          && request.resource.data.senderId == request.auth.uid
          && (
            listHas(get(/databases/$(database)/documents/conversations/$(conversationId)).data, 'participantIds', request.auth.uid) ||
            listHas(get(/databases/$(database)/documents/conversations/$(conversationId)).data, 'participants', request.auth.uid)
          );
        allow update, delete: if false;
      }
    }

    // ===== CATCH-ALL =====
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
