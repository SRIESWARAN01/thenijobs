# Used by scripts/seed/taxonomy.mjs.
# Option A: authenticate with Application Default Credentials.
# Option B: set GOOGLE_APPLICATION_CREDENTIALS to a Firebase service account JSON path.
GOOGLE_APPLICATION_CREDENTIALS=
