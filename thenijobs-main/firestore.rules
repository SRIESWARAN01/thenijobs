rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function userRole() {
      return isAuthenticated()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function currentUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return userRole() in ['admin', 'super_admin'];
    }

    function isEmployer() {
      return userRole() in ['employer', 'business_owner'];
    }

    function isMobileVerified() {
      return isAuthenticated()
        && (
          isAdmin()
          || currentUserData().get('mobileVerified', false) == true
          || currentUserData().get('phoneVerified', false) == true
        );
    }

    function isAllowedSelfRole(role) {
      return role in ['job_seeker', 'employer', 'business_owner'];
    }

    function onlyChanged(allowedKeys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowedKeys);
    }

    function isValidUserCreate(userId) {
      return isOwner(userId)
        && isAllowedSelfRole(request.resource.data.role)
        && request.resource.data.keys().hasAll(['email', 'displayName', 'role'])
        && (
          (
            request.resource.data.get('mobileVerified', false) == false
            && request.resource.data.get('phoneVerified', false) == false
          )
          || (
            request.auth.token.phone_number != null
            && request.resource.data.get('phone', '') == request.auth.token.phone_number
            && request.resource.data.get('mobileVerified', false) == true
            && request.resource.data.get('phoneVerified', false) == true
          )
        );
    }

    function isCompanyOwner(companyId) {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/companies/$(companyId))
        && get(/databases/$(database)/documents/companies/$(companyId)).data.ownerId == request.auth.uid;
    }

    function companyData(companyId) {
      return get(/databases/$(database)/documents/companies/$(companyId)).data;
    }

    function companyPlan(companyId) {
      return exists(/databases/$(database)/documents/companies/$(companyId))
        && companyData(companyId).keys().hasAny(['subscriptionPlan'])
        ? companyData(companyId).subscriptionPlan
        : exists(/databases/$(database)/documents/companies/$(companyId))
          && companyData(companyId).keys().hasAny(['plan'])
        ? companyData(companyId).plan
        : 'free';
    }

    function isPremiumCompanyPlan(companyId) {
      return companyPlan(companyId) in ['premium', 'enterprise'];
    }

    function requestedJobBoostsAllowed(companyId) {
      return isPremiumCompanyPlan(companyId)
        || (
          (!request.resource.data.keys().hasAny(['isFeatured']) || request.resource.data.isFeatured == false)
          && (!request.resource.data.keys().hasAny(['isUrgent']) || request.resource.data.isUrgent == false)
          && (!request.resource.data.keys().hasAny(['isPremium']) || request.resource.data.isPremium == false)
        );
    }

    function isValidCompanyCreate() {
      return isAuthenticated()
        && request.resource.data.ownerId == request.auth.uid
        && (!request.resource.data.keys().hasAny(['verificationStatus']) || request.resource.data.verificationStatus == 'pending')
        && (!request.resource.data.keys().hasAny(['isActive']) || request.resource.data.isActive == false)
        && (!request.resource.data.keys().hasAny(['isFeatured']) || request.resource.data.isFeatured == false)
        && (!request.resource.data.keys().hasAny(['isPremium']) || request.resource.data.isPremium == false)
        && (!request.resource.data.keys().hasAny(['subscriptionPlan']) || request.resource.data.subscriptionPlan == 'free')
        && (!request.resource.data.keys().hasAny(['plan']) || request.resource.data.plan == 'free')
        && (!request.resource.data.keys().hasAny(['subscriptionStatus']) || request.resource.data.subscriptionStatus == 'active')
        && !request.resource.data.keys().hasAny([
          'isVerified',
          'approvedBy',
          'approvedAt',
          'rejectionReason'
        ]);
    }

    function isValidJobCreate() {
      return isAuthenticated()
        && request.resource.data.postedBy == request.auth.uid
        && isCompanyOwner(request.resource.data.companyId)
        && requestedJobBoostsAllowed(request.resource.data.companyId)
        && !request.resource.data.keys().hasAny(['approvedBy', 'approvedAt']);
    }

    function isValidJobOwnerUpdate() {
      return resource.data.postedBy == request.auth.uid
        && request.resource.data.postedBy == resource.data.postedBy
        && request.resource.data.companyId == resource.data.companyId
        && requestedJobBoostsAllowed(resource.data.companyId)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'postedBy',
          'companyId',
          'companyName',
          'companySlug',
          'approvedBy',
          'approvedAt',
          'applicationCount',
          'viewCount',
          'isPremium',
          'isFeatured',
          'isUrgent',
          'planAtCreation'
        ])
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'isActive'])
          || (
            request.resource.data.status == 'closed'
            && request.resource.data.isActive == false
          )
          || (
            resource.data.status in ['active', 'paused']
            && request.resource.data.status in ['active', 'paused']
            && request.resource.data.isActive == (request.resource.data.status == 'active')
          )
        );
    }

    function isApplicationCountIncrement() {
      return isAuthenticated()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['applicationCount', 'updatedAt'])
        && request.resource.data.applicationCount == resource.data.get('applicationCount', 0) + 1;
    }

    function isParticipant(conversationId) {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/conversations/$(conversationId))
        && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
    }

    // ===== USERS =====
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isValidUserCreate(userId) || isAdmin();
      allow update: if isAdmin()
        || (
          isOwner(userId)
          && onlyChanged([
            'displayName',
            'email',
            'photoURL',
            'phone',
            'address',
            'district',
            'theniJobsId',
            'skills',
            'experience',
            'education',
            'certifications',
            'portfolioLinks',
            'profileScore',
            'aiSummary',
            'smartIdTheme',
            'preferences',
            'updatedAt'
          ])
        );
      allow delete: if isAdmin();
    }

    // ===== PUBLIC DIRECTORY =====
    match /companies/{companyId} {
      allow read: if true;
      allow create: if isValidCompanyCreate();
      allow update: if isAdmin()
        || (
          resource.data.ownerId == request.auth.uid
          && request.resource.data.ownerId == resource.data.ownerId
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'ownerId',
            'subscriptionPlan',
            'subscriptionStatus',
            'plan',
            'verification',
            'verificationBadges',
            'verificationStatus',
            'isVerified',
            'isFeatured',
            'isPremium',
            'approvedBy',
            'approvedAt',
            'rejectionReason'
          ])
        );
      allow delete: if isAdmin();
    }

    match /jobs/{jobId} {
      allow read: if true;
      allow create: if isValidJobCreate();
      allow update: if isAdmin()
        || isApplicationCountIncrement()
        || isValidJobOwnerUpdate();
      allow delete: if isAdmin() || resource.data.postedBy == request.auth.uid;
    }

    match /services/{serviceId} {
      allow read: if true;
      allow create: if isMobileVerified();
      allow update, delete: if isAdmin()
        || ((resource.data.providerId == request.auth.uid || resource.data.ownerId == request.auth.uid) && isMobileVerified());
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isMobileVerified()
        && request.resource.data.reviewerId == request.auth.uid;
      allow update, delete: if isAdmin() || (resource.data.reviewerId == request.auth.uid && isMobileVerified());
    }

    match /advertisements/{adId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ===== JOB SEEKER DATA =====
    match /seekerProfiles/{userId} {
      allow read: if isOwner(userId) || isEmployer() || isAdmin();
      allow create, update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /savedJobs/{savedJobId} {
      allow read, delete: if isAdmin() || resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || resource.data.userId == request.auth.uid;
    }

    match /jobAlerts/{alertId} {
      allow read, update, delete: if isAdmin() || resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
    }

    match /applications/{applicationId} {
      allow read: if isAdmin()
        || resource.data.seekerId == request.auth.uid
        || resource.data.employerId == request.auth.uid
        || resource.data.postedBy == request.auth.uid
        || isCompanyOwner(resource.data.companyId);
      allow create: if isAuthenticated()
        && request.resource.data.seekerId == request.auth.uid;
      allow update: if isAdmin()
        || resource.data.seekerId == request.auth.uid
        || resource.data.employerId == request.auth.uid
        || resource.data.postedBy == request.auth.uid
        || isCompanyOwner(resource.data.companyId);
      allow delete: if isAdmin();
    }

    match /interviews/{interviewId} {
      allow read: if isAdmin()
        || resource.data.seekerId == request.auth.uid
        || resource.data.employerId == request.auth.uid
        || isCompanyOwner(resource.data.companyId);
      allow create: if isAdmin()
        || (
          isMobileVerified()
          && (
            request.resource.data.employerId == request.auth.uid
            || isCompanyOwner(request.resource.data.companyId)
          )
        );
      allow update: if isAdmin()
        || (
          isMobileVerified()
          && (
            resource.data.seekerId == request.auth.uid
            || resource.data.employerId == request.auth.uid
            || isCompanyOwner(resource.data.companyId)
          )
        );
      allow delete: if isAdmin();
    }

    // ===== COMMUNICATION =====
    match /notifications/{notificationId} {
      allow read, update, delete: if isAdmin() || resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated()
        && (
          isAdmin()
          || request.resource.data.userId == request.auth.uid
          || request.resource.data.createdBy == request.auth.uid
        )
        && request.resource.data.keys().hasAll(['userId', 'type', 'title', 'message', 'read', 'createdAt']);
    }

    match /broadcasts/{broadcastId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /conversations/{conversationId} {
      allow read, update, delete: if isAdmin() || request.auth.uid in resource.data.participants;
      allow create: if isMobileVerified()
        && request.auth.uid in request.resource.data.participants;

      match /messages/{messageId} {
        allow read, update, delete: if isAdmin() || isParticipant(conversationId);
        allow create: if isParticipant(conversationId)
          && isMobileVerified()
          && request.resource.data.senderId == request.auth.uid;
      }
    }

    // ===== BUSINESS OPS =====
    match /leads/{leadId} {
      allow read, update, delete: if isAdmin()
        || resource.data.assignedTo == request.auth.uid
        || resource.data.ownerId == request.auth.uid
        || isCompanyOwner(resource.data.companyId);
      allow create: if isMobileVerified()
        && request.resource.data.keys().hasAll(['name', 'phone', 'message', 'createdAt'])
        && !request.resource.data.keys().hasAny(['assignedTo', 'convertedBy']);
    }

    match /subscriptions/{subscriptionId} {
      allow read: if isAdmin()
        || resource.data.userId == request.auth.uid
        || isCompanyOwner(resource.data.companyId);
      // Paid plan changes must be written by admin/back-end payment webhooks.
      allow create, update, delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if isAdmin()
        || resource.data.userId == request.auth.uid
        || isCompanyOwner(resource.data.companyId);
      allow create, update, delete: if isAdmin();
    }

    match /supportTickets/{ticketId} {
      allow read, update: if isAdmin() || resource.data.userId == request.auth.uid;
      allow create: if isMobileVerified()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ===== ADMIN / AUDIT =====
    match /activityLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll(['userId', 'userName', 'action', 'target', 'targetId', 'timestamp']);
      allow update, delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ===== PUBLIC SMART ID / PORTFOLIO PAGES =====
    match /publicProfiles/{profileId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.type in ['job_seeker', 'employer', 'business_owner'];
      allow update: if isAdmin()
        || (
          resource.data.ownerId == request.auth.uid
          && request.resource.data.ownerId == resource.data.ownerId
          && request.resource.data.type == resource.data.type
        );
      allow delete: if isAdmin() || resource.data.ownerId == request.auth.uid;
    }

    // ===== GAMIFICATION =====
    match /gamification/{userId} {
      // Allow any authenticated user to read for leaderboard access
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      match /activities/{activityId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) || isAdmin();
        allow update, delete: if isAdmin();
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
